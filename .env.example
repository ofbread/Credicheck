# Required for retrieval and generation phases (LLM inference via OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key

# Required for retrieval phase (web search via Serper/Google)
SERPER_API_KEY=your_serper_api_key

# Required for credibility scoring (CrediGraph domain credibility API)
CREDIGRAPH_TOKEN=your_credigraph_token
